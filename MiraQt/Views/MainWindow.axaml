<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MiraQt.ViewModels"
        xmlns:m="using:MiraQt.Models"
        xmlns:v="using:MiraQt.Views"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="600"
        x:Class="MiraQt.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="MiraQt — Network Displays"
        Width="520" Height="600"
        MinWidth="380" MinHeight="400"
        Background="{StaticResource SurfaceBgBrush}">

    <Window.Styles>
        <Style Selector="Border.display-card">
            <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="Border.display-card:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource BrandAccentBrush}" />
        </Style>

        <Style Selector="Ellipse.status-pip">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource BrandAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandAccentHoverBrush}" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource StateErrorBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceCardBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="MiraQt"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Wireless display for KDE Plasma"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceCardBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Classes="status-pip" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding IsDaemonConnected, Converter={x:Static v:BoolToColorConverter.Instance}}" />
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <Grid Margin="20,16">
            <StackPanel IsVisible="{Binding !HasDisplays}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="10">
                <TextBlock Text="🛰"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}" />
                <TextBlock Text="Searching for nearby displays"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Make sure your TV is in cast / Miracast mode"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ScrollViewer IsVisible="{Binding HasDisplays}"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Displays}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="m:DisplayInfo">
                            <Border Classes="display-card">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ProtocolLabel}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                Margin="0,8,0,0">
                                        <Ellipse Classes="status-pip" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding State, Converter={x:Static v:StateToColorConverter.Instance}}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding StateLabel}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Grid Grid.Column="1" Grid.RowSpan="2"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0">
                                        <Button Classes="primary"
                                                Content="Connect"
                                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ConnectDisplayCommand}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding !IsConnected}"
                                                IsEnabled="{Binding !IsBusy}" />
                                        <Button Classes="danger"
                                                Content="Disconnect"
                                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).DisconnectDisplayCommand}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding IsConnected}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
